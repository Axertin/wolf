#pragma once

// Auto-generated version information
#define WOLF_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define WOLF_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define WOLF_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define WOLF_VERSION_STRING "@PROJECT_VERSION_MAJOR@.@PROJECT_VERSION_MINOR@.@PROJECT_VERSION_PATCH@"

// Semantic version as single integer for comparisons
#define WOLF_VERSION_INT ((@PROJECT_VERSION_MAJOR@U << 24) | (@PROJECT_VERSION_MINOR@U << 16) | @PROJECT_VERSION_PATCH@U)

// Build information
#define WOLF_BUILD_TYPE "@CMAKE_BUILD_TYPE@"
#define WOLF_COMPILER "@CMAKE_CXX_COMPILER_ID@ @CMAKE_CXX_COMPILER_VERSION@"
